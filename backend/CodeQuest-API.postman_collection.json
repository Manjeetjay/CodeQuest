                            ]
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"title\": \"Two Sum\",\n  \"description\": \"Given an array of integers nums and an integer target, return indices of the two numbers such that they add up to target.\",\n  \"difficulty\": \"EASY\",\n  \"tags\": [\"array\", \"hash-table\"],\n  \"wrapperCode\": \"public class Solution {\\n    public int[] twoSum(int[] nums, int target) {\\n        // User code will be inserted here\\n    }\\n}\\n\",\n  \"templates\": [\n    {\n      \"languageId\": 62,\n      \"template\": \"// Write your solution here\\nreturn new int[]{0, 1};\"\n    }\n  ],\n  \"testCases\": [\n    {\n      \"input\": \"[2,7,11,15]\\n9\",\n      \"output\": \"[0,1]\",\n      \"sample\": true\n    },\n    {\n      \"input\": \"[3,2,4]\\n6\",\n      \"output\": \"[1,2]\",\n      \"sample\": false\n    }\n  ]\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/admin/problem",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "admin",
                                "problem"
                            ]
                        }
                    },
                    "response": []
                },
