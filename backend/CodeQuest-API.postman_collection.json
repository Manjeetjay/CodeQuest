        {
            "name": "Admin - Problems",
            "item": [
                {
                    "name": "Create Problem",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{token}}",
                                    "type": "string"
